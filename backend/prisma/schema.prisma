generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  phone         String?
  password_hash String
  created_at    DateTime    @default(now())
  cart_items    CartItem[]
  orders        Order[]
}

model Seller {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  phone         String
  whatsapp      String?
  shop_name     String
  shop_desc     String?
  password_hash String
  is_approved   Boolean    @default(false)
  created_at    DateTime   @default(now())
  products      Product[]
  orders        Order[]
}

model Admin {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  created_at    DateTime @default(now())
}

model Product {
  id             String      @id @default(uuid())
  seller_id      String
  name           String
  name_fr        String
  description    String
  description_fr String
  price          Decimal     @db.Decimal(12, 2)
  category       String
  image_url      String
  in_stock       Boolean     @default(true)
  stock_qty      Int         @default(1)
  created_at     DateTime    @default(now())
  seller         Seller      @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  cart_items     CartItem[]
  order_items    OrderItem[]

  @@index([seller_id])
  @@index([category])
}

model CartItem {
  id         String   @id @default(uuid())
  user_id    String
  product_id String
  quantity   Int      @default(1)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
}

model Order {
  id               String      @id @default(uuid())
  user_id          String?
  seller_id        String?
  total_amount     Decimal     @db.Decimal(12, 2)
  status           OrderStatus @default(pending)
  payment_status   PayStatus   @default(unpaid)
  payment_method   String?
  delivery_address String?
  created_at       DateTime    @default(now())
  user             User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  seller           Seller?     @relation(fields: [seller_id], references: [id], onDelete: SetNull)
  order_items      OrderItem[]
  payments         Payment[]

  @@index([user_id])
  @@index([seller_id])
}

model OrderItem {
  id         String   @id @default(uuid())
  order_id   String
  product_id String?
  quantity   Int
  unit_price Decimal  @db.Decimal(12, 2)
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([order_id])
}

model Payment {
  id           String        @id @default(uuid())
  order_id     String
  monetbil_ref String?       @unique
  amount       Decimal       @db.Decimal(12, 2)
  phone        String
  operator     String?
  status       PaymentStatus @default(pending)
  created_at   DateTime      @default(now())
  order        Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum PayStatus {
  unpaid
  paid
  failed
  refunded
}

enum PaymentStatus {
  pending
  success
  failed
}
